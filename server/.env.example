# 服务端口
PORT=8787

# 数据库（zero-mysql-dev 容器，映射在本机 3307）
DATABASE_URL=mysql://zero:zero@127.0.0.1:3307/zero

# JWT 签名密钥（生产环境务必替换为随机长字符串）
JWT_SECRET=change-me-in-prod

# 允许的前端来源（CORS）
CORS_ORIGIN=http://localhost:5173

# 邮件里 issue 链接的 web 基址
APP_URL=http://localhost:5173

# 邮件通知（SMTP）。未配置 SMTP_HOST 时，邮件 adapter 进 dev 回退：
# 只把内容打到控制台、不真正发信（便于无凭据先验证整条通知管线）。
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true          # 465 用 true；587(STARTTLS) 用 false
SMTP_USER=
SMTP_PASS=                # 密码 / 授权码（QQ、163 用「授权码」而非登录密码）
SMTP_FROM=                # 发件地址，如 noreply@yourdomain
SMTP_FROM_NAME=Zero

# 企业微信「智能机器人」（长连接）。后台「API 配置 → 长连接」处拿 Bot ID + Secret。
# 未配置则不启动。绑定走设置页「绑定码」。
WECOM_BOT_ID=
WECOM_BOT_SECRET=

# Telegram bot。token 来自 @BotFather。
# TELEGRAM_PROXY：本机直连不了 Telegram 时填代理（如 http://127.0.0.1:7890）。
# 未配置 token 则不启动。绑定走设置页「绑定码」（也支持 /start <码>）。
TELEGRAM_BOT_TOKEN=
TELEGRAM_PROXY=
